{
	"name": "@tammergard/prettier-config",
	"version": "3.0.1",
	"description": "A sharable Prettier config with personal preferences",
	"keywords": [
		"prettier",
		"config",
		"prettier-config",
		"style-guide"
	],
	"homepage": "https://github.com/filiptammergard/prettier-config#readme",
	"bugs": {
		"url": "https://github.com/filiptammergard/prettier-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filiptammergard/prettier-config.git"
	},
	"license": "MIT",
	"author": {
		"name": "Filip Tammergård",
		"email": "filip+npm@tammergard.se",
		"url": "https://tammergard.se"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./index.js"
	},
	"main": "index.js",
	"files": [
		"index.js"
	],
	"scripts": {
		"format": "prettier --write .",
		"format-check": "prettier --check .",
		"release": "pnpm changeset publish",
		"review": "pnpm install --frozen-lockfile && pnpm format-check"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"prettier": "^3.8.3"
	},
	"peerDependencies": {
		"prettier": ">=3.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24",
			"onFail": "error"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
